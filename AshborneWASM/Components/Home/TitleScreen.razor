<div class="title-screen @(IsFading ? "fade-out" : "") @(IsIntroTransitioning ? "fade-overlap" : "")">
    <div class="title-logo">ASHBORNE</div>
    <button class="begin-button" @onclick="OnBegin">Begin</button>
    <button class="continue-button" @onclick="OnContinue">Continue</button>
</div>

@code {
    [Parameter] public bool IsFading { get; set; }
    [Parameter] public bool IsIntroTransitioning { get; set; }
    [Parameter] public EventCallback OnBegin { get; set; }
    [Parameter] public EventCallback OnContinue { get; set; }
}
